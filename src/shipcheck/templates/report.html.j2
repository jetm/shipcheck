<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>shipcheck Compliance Report</title>
<style>
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    margin: 0;
    padding: 2rem;
    background: #f8f9fa;
    color: #212529;
    line-height: 1.6;
  }
  .container { max-width: 900px; margin: 0 auto; }
  h1 { margin-bottom: 0.25rem; }
  .subtitle { color: #6c757d; margin-bottom: 1.5rem; }
  .meta-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 2rem;
    background: #fff;
    border: 1px solid #dee2e6;
  }
  .meta-table th {
    text-align: left;
    padding: 0.5rem 0.75rem;
    background: #e9ecef;
    border: 1px solid #dee2e6;
    width: 200px;
  }
  .meta-table td {
    padding: 0.5rem 0.75rem;
    border: 1px solid #dee2e6;
  }
  .checks-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 2rem;
    background: #fff;
    border: 1px solid #dee2e6;
  }
  .checks-table th {
    text-align: left;
    padding: 0.5rem 0.75rem;
    background: #343a40;
    color: #fff;
    border: 1px solid #dee2e6;
  }
  .checks-table td {
    padding: 0.5rem 0.75rem;
    border: 1px solid #dee2e6;
    vertical-align: top;
  }
  .status-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    font-weight: bold;
    font-size: 0.85rem;
  }
  .status-pass { background: #d4edda; color: #155724; }
  .status-fail { background: #f8d7da; color: #721c24; }
  .status-warn { background: #fff3cd; color: #856404; }
  .status-skip { background: #e2e3e5; color: #383d41; }
  .findings-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 0.5rem;
  }
  .findings-table th {
    text-align: left;
    padding: 0.35rem 0.5rem;
    background: #f1f3f5;
    border: 1px solid #dee2e6;
    font-size: 0.85rem;
  }
  .findings-table td {
    padding: 0.35rem 0.5rem;
    border: 1px solid #dee2e6;
    font-size: 0.85rem;
  }
  .severity-badge {
    display: inline-block;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-weight: bold;
    font-size: 0.75rem;
    text-transform: uppercase;
  }
  .severity-critical { background: #dc3545; color: #fff; }
  .severity-high { background: #fd7e14; color: #fff; }
  .severity-medium { background: #ffc107; color: #212529; }
  .severity-low { background: #17a2b8; color: #fff; }
  .score-section {
    text-align: center;
    padding: 1.5rem;
    background: #fff;
    border: 1px solid #dee2e6;
    border-radius: 4px;
  }
  .score-value {
    font-size: 2.5rem;
    font-weight: bold;
  }
  .score-label {
    color: #6c757d;
    font-size: 1rem;
  }
  .footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #dee2e6;
    color: #6c757d;
    font-size: 0.85rem;
  }
</style>
</head>
<body>
<div class="container">
  <h1>shipcheck v{{ report.shipcheck_version }}</h1>
  <p class="subtitle">Embedded Linux Compliance Auditor</p>

  <table class="meta-table">
    <tr><th>Build directory</th><td>{{ report.build_dir }}</td></tr>
    <tr><th>Framework</th><td>{{ report.framework }} {{ report.framework_version }}</td></tr>
    <tr><th>BSI TR</th><td>{{ report.bsi_tr_version }}</td></tr>
    <tr><th>Timestamp</th><td>{{ report.timestamp }}</td></tr>
  </table>

  <h2>Check Results</h2>
  <table class="checks-table">
    <tr>
      <th>Status</th>
      <th>Check</th>
      <th>Score</th>
      <th>Summary</th>
    </tr>
    {% for check in report.checks %}
    <tr>
      <td><span class="status-badge status-{{ check.status.value }}">{{ check.status.value|upper }}</span></td>
      <td>{{ check.check_name }}</td>
      <td>{{ check.score }}/{{ check.max_score }}</td>
      <td>{{ check.summary }}</td>
    </tr>
    {% if check.findings %}
    <tr>
      <td colspan="4">
        <table class="findings-table">
          <tr>
            <th>Severity</th>
            <th>Finding</th>
            <th>Remediation</th>
          </tr>
          {% for finding in check.findings %}
          <tr>
            <td><span class="severity-badge severity-{{ finding.severity }}">{{ finding.severity }}</span></td>
            <td>{{ finding.message }}</td>
            <td>{{ finding.remediation if finding.remediation else "" }}</td>
          </tr>
          {% endfor %}
        </table>
      </td>
    </tr>
    {% endif %}
    {% endfor %}
  </table>

  <div class="score-section">
    <div class="score-value">{{ report.total_score }}/{{ report.max_total_score }}</div>
    <div class="score-label">Readiness Score</div>
  </div>

  <div class="footer">
    Generated by shipcheck v{{ report.shipcheck_version }} on {{ report.timestamp }}
  </div>
</div>
</body>
</html>
